# =============================================================================
# Eco-Auditor — Required Environment Variables
# =============================================================================
# Copy this file to .env for local development.
# In Railway: set each variable under your service's "Variables" tab.
# Values must NOT be quoted in Railway's variable editor.
# =============================================================================

# -----------------------------------------------------------------------------
# InsForge Backend (required)
# Find these in your InsForge project dashboard → Settings → API
# -----------------------------------------------------------------------------

# Your InsForge project's base URL (no trailing slash)
VITE_INSFORGE_BASE_URL=https://your-project.region.insforge.app

# InsForge anonymous (public) API key — safe to expose to the browser
VITE_INSFORGE_ANON_KEY=ik_your_anon_key_here

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# • All VITE_* variables are inlined into the client bundle at build time by
#   Vite.  Do NOT store server-side secrets here.
# • The InsForge anon key is designed to be public — Row Level Security (RLS)
#   policies on the backend enforce data access boundaries.
# • If you add a service-role key for server-side operations, store it as a
#   non-VITE_ variable and access it only from secure server-side code.
