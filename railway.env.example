# Eco-Auditor Railway Environment Variables
# Copy this file as reference when configuring Railway service variables.
#
# Set via: railway variables set KEY=VALUE
# Or via: Railway Dashboard → Service → Variables

# ─── Required ───

# Port for the Express server (Railway injects this automatically)
PORT=3000

# Node environment
NODE_ENV=production

# Forces Nixpacks/Dockerfile to use Node 22 (required for Vite 8)
NIXPACKS_NODE_VERSION=22

# InsForge backend URL (Vite embeds this at build time)
VITE_INSFORGE_BASE_URL=https://your-insforge-app.up.railway.app

# InsForge anonymous key (Vite embeds this at build time)
VITE_INSFORGE_ANON_KEY=your-insforge-anon-key

# ─── Stripe (required for billing) ───

# Stripe publishable key (Vite embeds this at build time)
VITE_STRIPE_PK=pk_live_your_publishable_key

# Stripe secret key (server-side only, not embedded in frontend)
STRIPE_SECRET_KEY=sk_live_your_secret_key

# Stripe webhook signing secret (server-side only)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Optional ───

# Custom domain (set via Railway dashboard or CLI)
# RAILWAY_DOMAIN=eco-auditor.developer312.com